# ============================================
# CraftFlow 桌面端配置（standalone 模式）
# ============================================
# 桌面端模式特点：
# - SQLite 存储，零配置
# - 无鉴权，单机使用
# - 数据存储在本地

# ============================================
# 应用模式配置
# ============================================
APP_MODE=standalone
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# 鉴权配置（standalone 模式下自动禁用）
# ============================================
ENABLE_AUTH=false
# API_KEY 在 standalone 模式下无效

# ============================================
# LLM 配置（已迁移至数据库）
# ============================================
# LLM 配置通过前端设置页面管理，存储在 SQLite 的 llm_profiles 表中。
# 首次使用时请在前端设置页面添加 LLM Profile。

# ============================================
# 状态持久化配置（SQLite）
# ============================================
# 桌面端（PyInstaller 打包）自动使用 %APPDATA%/CraftFlow/ 目录，
# 以下路径仅在 Web 端开发/部署时生效。
CHECKPOINTER_BACKEND=sqlite
TASKSTORE_BACKEND=sqlite

# PostgreSQL 配置（standalone 模式下不使用）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/craftflow

# ============================================
# 外部工具 API 配置（已迁移至数据库）
# ============================================
# Tavily Search API Key 和 E2B Code Sandbox API Key
# 现在通过前端设置页面管理，存储在 SQLite 的 settings 表中。

# ============================================
# 向量数据库配置
# ============================================
ENABLE_RAG=false
VECTOR_DB_BACKEND=chroma
VECTOR_COLLECTION_NAME=craftflow_docs

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_DIMENSIONS=1536

# ============================================
# FastAPI 服务配置
# ============================================
HOST=127.0.0.1
PORT=8000
RELOAD=false
WORKERS=1

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# ============================================
# 业务逻辑配置（已迁移至数据库）
# ============================================
# max_outline_sections, max_concurrent_writers, max_debate_iterations,
# editor_pass_score, task_timeout, tool_call_timeout
# 现在通过前端设置页面管理，存储在 SQLite 的 settings 表中。
