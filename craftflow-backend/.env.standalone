# ============================================
# CraftFlow 桌面端配置（standalone 模式）
# ============================================
# 桌面端模式特点：
# - SQLite 存储，零配置
# - 无鉴权，单机使用
# - 数据存储在本地

# ============================================
# 应用模式配置
# ============================================
APP_MODE=standalone
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# 鉴权配置（standalone 模式下自动禁用）
# ============================================
ENABLE_AUTH=false
# API_KEY 在 standalone 模式下无效

# ============================================
# LLM 配置
# ============================================
LLM_API_KEY=sk-your-openai-api-key-here
LLM_API_BASE=
LLM_MODEL=gpt-4-turbo
MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.7

# ============================================
# 状态持久化配置（SQLite）
# ============================================
# 桌面端（PyInstaller 打包）自动使用 %APPDATA%/CraftFlow/ 目录，
# 以下路径仅在 Web 端开发/部署时生效。
CHECKPOINTER_BACKEND=sqlite
TASKSTORE_BACKEND=sqlite

# PostgreSQL 配置（standalone 模式下不使用）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/craftflow

# ============================================
# 外部工具 API 配置
# ============================================
TAVILY_API_KEY=tvly-your-tavily-api-key-here
E2B_API_KEY=your-e2b-api-key-here

# ============================================
# 向量数据库配置
# ============================================
ENABLE_RAG=false
VECTOR_DB_BACKEND=chroma
VECTOR_COLLECTION_NAME=craftflow_docs

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_DIMENSIONS=1536

# ============================================
# FastAPI 服务配置
# ============================================
HOST=127.0.0.1
PORT=8000
RELOAD=false
WORKERS=1

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# ============================================
# 业务逻辑配置
# ============================================
MAX_OUTLINE_SECTIONS=10
MAX_CONCURRENT_WRITERS=5
MAX_DEBATE_ITERATIONS=3
EDITOR_PASS_SCORE=90
TASK_TIMEOUT=3600
TOOL_CALL_TIMEOUT=30
