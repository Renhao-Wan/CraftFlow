# ============================================
# CraftFlow Backend 环境变量配置说明
# ============================================
#
# 本文件列出所有可用的环境变量及其说明，供开发者参考。
#
# 使用方式：
# - 桌面端开发：直接使用 .env.standalone
# - 服务端开发：直接使用 .env.server
# - 本地开发：使用 .env.dev（已配置）
# - 自定义配置：复制本文件为 .env.xxx 并填写
#
# 文件说明：
# - .env.example    - 配置说明文档（本文件）
# - .env.standalone - 桌面端默认配置（可直接使用）
# - .env.server     - 服务端默认配置（可直接使用）
# - .env.dev        - 本地开发配置（已配置，勿提交）
#
# 切勿将包含真实密钥的 .env 文件提交到 Git！

# ============================================
# 应用基础配置
# ============================================
# APP_NAME: 应用名称
# APP_VERSION: 应用版本
# APP_MODE: 运行模式
#   - standalone: 桌面端模式，SQLite，无鉴权，零配置
#   - server: 服务端模式，PostgreSQL，API Key 鉴权
# ENVIRONMENT: 运行环境
#   - development: 开发环境（显示 API 文档）
#   - production: 生产环境（隐藏 API 文档）
# DEBUG: 调试模式（true/false）
# LOG_LEVEL: 日志级别（DEBUG/INFO/WARNING/ERROR）
APP_NAME="CraftFlow Backend"
APP_VERSION="0.1.0"
APP_MODE="standalone"
ENVIRONMENT="development"
DEBUG=true
LOG_LEVEL="INFO"

# ============================================
# 鉴权配置
# ============================================
# ENABLE_AUTH: 是否启用 API Key 鉴权
#   - standalone 模式下自动禁用
#   - server 模式下建议启用
# API_KEY: API Key，用于验证 Java 后端调用
#   - server 模式下必须修改为强密钥
#   - 请求头 X-API-Key 传递
ENABLE_AUTH=false
API_KEY="craftflow-dev-key"

# ============================================
# LLM 配置
# ============================================
# LLM_API_KEY: LLM API 密钥（必填）
# LLM_API_BASE: LLM API 基础 URL（可选，留空使用默认）
# LLM_MODEL: 默认 LLM 模型
# MAX_TOKENS: 最大 Token 数（1-128000）
# DEFAULT_TEMPERATURE: 默认温度参数（0.0-2.0）
LLM_API_KEY="sk-your-openai-api-key-here"
LLM_API_BASE=""
LLM_MODEL="gpt-4-turbo"
MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.7

# ============================================
# 状态持久化配置
# ============================================
# CHECKPOINTER_BACKEND: Checkpointer 后端
#   - memory: 内存存储，进程退出即丢失（快速调试）
#   - sqlite: SQLite 持久化，零配置（推荐桌面端和开发环境）
#   - postgres: PostgreSQL 持久化（推荐服务端生产环境）
#   SQLite 路径基于代码位置自动推导，无需配置。
CHECKPOINTER_BACKEND="sqlite"

# TASKSTORE_BACKEND: TaskStore 后端
#   - sqlite: SQLite 持久化（推荐桌面端和开发环境）
#   - postgres: PostgreSQL 持久化（推荐服务端生产环境）
#   SQLite 路径基于代码位置自动推导，无需配置。
TASKSTORE_BACKEND="sqlite"

# DATABASE_URL: PostgreSQL 连接串
#   - checkpointer_backend=postgres 或 taskstore_backend=postgres 时必填
#   - 格式：postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/craftflow"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# 外部工具 API 配置
# ============================================
# TAVILY_API_KEY: Tavily Search API 密钥（互联网搜索）
# E2B_API_KEY: E2B Code Interpreter API 密钥（代码沙箱）
TAVILY_API_KEY="tvly-your-tavily-api-key-here"
E2B_API_KEY="your-e2b-api-key-here"

# ============================================
# 向量数据库配置
# ============================================
# ENABLE_RAG: 是否启用 RAG（检索增强生成）功能
# VECTOR_DB_BACKEND: 向量数据库后端
#   - pgvector: PostgreSQL + pgvector 扩展（推荐生产）
#   - chroma: 本地文件存储（推荐开发）
# VECTOR_COLLECTION_NAME: 向量数据库集合名称
ENABLE_RAG=false
VECTOR_DB_BACKEND="pgvector"
VECTOR_COLLECTION_NAME="craftflow_docs"

# EMBEDDING_MODEL: Embedding 模型名称
#   - OpenAI: text-embedding-3-small, text-embedding-3-large
# EMBEDDING_API_KEY: Embedding API 密钥（留空使用 LLM_API_KEY）
# EMBEDDING_API_BASE: Embedding API 基础 URL（留空使用 LLM_API_BASE）
# EMBEDDING_DIMENSIONS: Embedding 向量维度
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_API_KEY=""
EMBEDDING_API_BASE=""
EMBEDDING_DIMENSIONS=1536

# ============================================
# FastAPI 服务配置
# ============================================
# HOST: 服务监听地址
#   - 127.0.0.1: 仅本地访问（推荐桌面端）
#   - 0.0.0.0: 允许外部访问（推荐服务端）
# PORT: 服务监听端口
# RELOAD: 热重载（仅开发环境）
# WORKERS: 工作进程数（生产环境建议 CPU 核心数）
HOST="0.0.0.0"
PORT=8000
RELOAD=true
WORKERS=1

# CORS_ORIGINS: 允许的跨域来源（逗号分隔）
# CORS_ALLOW_CREDENTIALS: 是否允许携带凭证
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
CORS_ALLOW_CREDENTIALS=true

# ============================================
# Redis 配置（可选，用于限流和缓存）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ============================================
# 业务逻辑配置
# ============================================
# MAX_OUTLINE_SECTIONS: 大纲最大章节数（1-50）
# MAX_CONCURRENT_WRITERS: 并发写作节点数量上限（1-20）
# MAX_DEBATE_ITERATIONS: 对抗循环最大迭代次数（1-10）
# EDITOR_PASS_SCORE: 主编通过分数阈值（0-100）
# TASK_TIMEOUT: 任务超时时间（秒，60-86400）
# TOOL_CALL_TIMEOUT: 工具调用超时时间（秒，5-300）
MAX_OUTLINE_SECTIONS=10
MAX_CONCURRENT_WRITERS=5
MAX_DEBATE_ITERATIONS=3
EDITOR_PASS_SCORE=90
TASK_TIMEOUT=3600
TOOL_CALL_TIMEOUT=30
