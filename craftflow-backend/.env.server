# ============================================
# CraftFlow 服务端配置（server 模式）
# ============================================
# 服务端模式特点：
# - PostgreSQL 存储，高可用
# - API Key 鉴权，保护服务安全
# - 云端部署，支持多用户

# ============================================
# 应用模式配置
# ============================================
APP_MODE=server
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# ============================================
# 鉴权配置
# ============================================
ENABLE_AUTH=true
API_KEY=your-strong-api-key-change-me

# ============================================
# LLM 配置（已迁移至数据库）
# ============================================
# LLM 配置通过前端设置页面管理，存储在数据库的 llm_profiles 表中。
# 首次使用时请在前端设置页面添加 LLM Profile。

# ============================================
# 状态持久化配置（PostgreSQL）
# ============================================
CHECKPOINTER_BACKEND=postgres
TASKSTORE_BACKEND=postgres

# PostgreSQL 连接配置（必填）
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/craftflow
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ============================================
# 外部工具 API 配置
# ============================================
TAVILY_API_KEY=tvly-your-tavily-api-key-here
E2B_API_KEY=your-e2b-api-key-here

# ============================================
# 向量数据库配置
# ============================================
ENABLE_RAG=true
VECTOR_DB_BACKEND=pgvector
VECTOR_COLLECTION_NAME=craftflow_docs

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_DIMENSIONS=1536

# ============================================
# FastAPI 服务配置
# ============================================
HOST=0.0.0.0
PORT=8000
RELOAD=false
WORKERS=4

CORS_ORIGINS=https://your-domain.com
CORS_ALLOW_CREDENTIALS=true

# ============================================
# Redis 配置（可选，用于限流和缓存）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ============================================
# 业务逻辑配置（已迁移至数据库）
# ============================================
# max_outline_sections, max_concurrent_writers, max_debate_iterations,
# editor_pass_score, task_timeout, tool_call_timeout
# 现在通过前端设置页面管理，存储在数据库的 settings 表中。
